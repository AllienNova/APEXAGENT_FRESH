{
  "name": "@apexagent/mobile",
  "version": "1.0.0",
  "description": "ApexAgent Mobile - Advanced AI System Mobile Application",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "detox test",
    "test:e2e:build": "detox build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "clean": "react-native clean",
    "clean:android": "cd android && ./gradlew clean && cd ..",
    "clean:ios": "cd ios && xcodebuild clean && cd ..",
    "build:android": "cd android && ./gradlew assembleRelease && cd ..",
    "build:ios": "cd ios && xcodebuild -workspace ApexAgent.xcworkspace -scheme ApexAgent -configuration Release archive && cd ..",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle",
    "bundle:ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle",
    "postinstall": "cd ios && pod install && cd ..",
    "pods": "cd ios && pod install && cd ..",
    "adb": "adb reverse tcp:3001 tcp:3001",
    "reset": "react-native start --reset-cache",
    "flipper": "react-native start --experimental-new-logbox",
    "codegen": "react-native codegen",
    "doctor": "react-native doctor"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.7",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/drawer": "^6.6.6",
    "@react-navigation/material-top-tabs": "^6.6.5",
    "react-native-screens": "^3.27.0",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^3.6.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-pager-view": "^6.2.3",
    "@reduxjs/toolkit": "^2.0.1",
    "react-redux": "^9.0.4",
    "redux-persist": "^6.0.0",
    "@react-native-async-storage/async-storage": "^1.19.5",
    "react-native-keychain": "^8.1.3",
    "react-native-biometrics": "^3.0.1",
    "@react-native-firebase/app": "^18.6.2",
    "@react-native-firebase/auth": "^18.6.2",
    "@react-native-firebase/firestore": "^18.6.2",
    "@react-native-firebase/storage": "^18.6.2",
    "@react-native-firebase/messaging": "^18.6.2",
    "@react-native-firebase/analytics": "^18.6.2",
    "@react-native-firebase/crashlytics": "^18.6.2",
    "react-native-config": "^1.5.1",
    "react-native-dotenv": "^3.4.9",
    "axios": "^1.6.2",
    "socket.io-client": "^4.7.4",
    "react-query": "^3.39.3",
    "react-native-vector-icons": "^10.0.2",
    "react-native-svg": "^14.0.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-blur": "^4.3.2",
    "react-native-shadow-2": "^7.0.8",
    "react-native-super-grid": "^4.9.7",
    "react-native-swipe-gestures": "^1.0.5",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-device-info": "^10.11.0",
    "react-native-permissions": "^4.0.0",
    "react-native-image-picker": "^7.0.3",
    "react-native-document-picker": "^9.1.1",
    "react-native-fs": "^2.20.0",
    "react-native-share": "^10.0.2",
    "react-native-clipboard": "^1.5.1",
    "react-native-toast-message": "^2.1.7",
    "react-native-modal": "^13.0.1",
    "react-native-actionsheet": "^2.4.2",
    "react-native-progress": "^5.0.1",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-shimmer": "^0.6.0",
    "react-native-animatable": "^1.4.0",
    "lottie-react-native": "^6.4.1",
    "react-native-sound": "^0.11.2",
    "react-native-voice": "^3.2.4",
    "@react-native-voice/voice": "^3.2.4",
    "react-native-tts": "^4.1.0",
    "react-native-background-job": "^0.2.7",
    "react-native-background-task": "^0.2.1",
    "@react-native-community/netinfo": "^11.2.1",
    "react-native-offline": "^6.0.2",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-mmkv": "^2.10.2",
    "react-native-flipper": "^0.212.0",
    "react-native-code-push": "^8.2.1",
    "react-native-version-check": "^3.4.7",
    "react-native-app-state": "^1.2.0",
    "react-native-orientation-locker": "^1.7.0",
    "react-native-status-bar-height": "^2.6.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-super-ellipse-mask": "^1.0.0",
    "react-native-fast-image": "^8.6.3",
    "react-native-webview": "^13.6.4",
    "react-native-markdown-display": "^7.0.0-alpha.2",
    "react-native-syntax-highlighter": "^2.1.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-calendars": "^1.1302.0",
    "react-native-date-picker": "^4.3.3",
    "react-native-picker-select": "^9.0.1",
    "react-native-slider": "^2.4.0",
    "react-native-switch": "^2.0.0",
    "react-native-segmented-control": "^2.4.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/runtime": "^7.23.5",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.12",
    "@tsconfig/react-native": "^3.0.2",
    "@types/react": "^18.2.43",
    "@types/react-test-renderer": "^18.0.7",
    "@types/jest": "^29.5.8",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "babel-jest": "^29.7.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^3.1.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.3.3",
    "detox": "^20.13.5",
    "@types/detox": "^18.1.0",
    "flipper-plugin-react-query": "^1.0.0",
    "flipper-plugin-redux-debugger": "^0.8.1",
    "reactotron-react-native": "^5.0.4",
    "reactotron-redux": "^3.1.9",
    "reactotron-redux-saga": "^4.2.3"
  },
  "resolutions": {
    "@types/react": "^18.2.43"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.(ts|tsx|js)",
      "**/*.(test|spec).(ts|tsx|js)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/index.tsx"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-vector-icons|react-native-svg|react-native-reanimated|react-native-gesture-handler|react-native-screens|@react-navigation|react-native-safe-area-context|react-native-tab-view|react-native-pager-view|@react-native-firebase|react-native-config|react-native-dotenv|react-native-super-grid|react-native-swipe-gestures|react-native-haptic-feedback|react-native-device-info|react-native-permissions|react-native-image-picker|react-native-document-picker|react-native-fs|react-native-share|react-native-clipboard|react-native-toast-message|react-native-modal|react-native-actionsheet|react-native-progress|react-native-skeleton-placeholder|react-native-shimmer|react-native-animatable|lottie-react-native|react-native-sound|react-native-voice|@react-native-voice|react-native-tts|react-native-background-job|react-native-background-task|@react-native-community|react-native-offline|react-native-sqlite-storage|react-native-mmkv|react-native-flipper|react-native-code-push|react-native-version-check|react-native-app-state|react-native-orientation-locker|react-native-status-bar-height|react-native-keyboard-aware-scroll-view|react-native-super-ellipse-mask|react-native-fast-image|react-native-webview|react-native-markdown-display|react-native-syntax-highlighter|react-native-chart-kit|react-native-calendars|react-native-date-picker|react-native-picker-select|react-native-slider|react-native-switch|react-native-segmented-control)/)"
    ]
  },
  "detox": {
    "test-runner": "jest",
    "runner-config": "e2e/config.json",
    "configurations": {
      "ios.sim.debug": {
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/ApexAgent.app",
        "build": "xcodebuild -workspace ios/ApexAgent.xcworkspace -scheme ApexAgent -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build",
        "type": "ios.simulator",
        "device": {
          "type": "iPhone 14 Pro"
        }
      },
      "android.emu.debug": {
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug && cd ..",
        "type": "android.emulator",
        "device": {
          "avdName": "Pixel_4_API_30"
        }
      }
    }
  }
}

