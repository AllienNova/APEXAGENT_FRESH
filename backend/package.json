{
  "name": "@apexagent/backend",
  "version": "1.0.0",
  "description": "ApexAgent Backend API - Advanced AI System Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "postbuild": "copyfiles -u 1 src/**/*.json dist/",
    "docker:build": "docker build -t apexagent-backend .",
    "docker:run": "docker run -p 3001:3001 apexagent-backend",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "studio": "prisma studio"
  },
  "keywords": [
    "ai",
    "artificial-intelligence",
    "api",
    "backend",
    "typescript",
    "express",
    "firebase",
    "openai",
    "anthropic",
    "google-ai"
  ],
  "author": "ApexAgent Team <team@apexagent.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AllienNova/ApexAgent.git",
    "directory": "backend"
  },
  "bugs": {
    "url": "https://github.com/AllienNova/ApexAgent/issues"
  },
  "homepage": "https://apexagent.ai",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-google-oauth20": "^2.0.0",
    "firebase-admin": "^12.0.0",
    "openai": "^4.24.1",
    "@anthropic-ai/sdk": "^0.13.1",
    "@google/generative-ai": "^0.2.1",
    "together-ai": "^0.5.2",
    "cohere-ai": "^7.7.5",
    "mistralai": "^0.1.3",
    "axios": "^1.6.2",
    "node-fetch": "^3.3.2",
    "ws": "^8.15.1",
    "socket.io": "^4.7.4",
    "redis": "^4.6.11",
    "ioredis": "^5.3.2",
    "bull": "^4.12.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.6.0",
    "xlsx": "^0.18.5",
    "csv-parser": "^3.0.0",
    "cheerio": "^1.0.0-rc.12",
    "puppeteer": "^21.6.1",
    "playwright": "^1.40.1",
    "zod": "^3.22.4",
    "joi": "^17.11.0",
    "ajv": "^8.12.0",
    "winston": "^3.11.0",
    "pino": "^8.17.2",
    "dotenv": "^16.3.1",
    "config": "^3.3.9",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "date-fns": "^2.30.0",
    "uuid": "^9.0.1",
    "nanoid": "^5.0.4",
    "crypto-js": "^4.2.0",
    "node-cron": "^3.0.3",
    "agenda": "^5.0.0",
    "nodemailer": "^6.9.7",
    "twilio": "^4.19.3",
    "stripe": "^14.9.0",
    "prometheus-client": "^15.1.0",
    "opentelemetry-api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.45.1",
    "@opentelemetry/instrumentation": "^0.45.1",
    "@opentelemetry/instrumentation-express": "^0.34.1",
    "@opentelemetry/instrumentation-http": "^0.45.1",
    "@opentelemetry/exporter-jaeger": "^1.18.1",
    "@opentelemetry/exporter-prometheus": "^0.45.1",
    "@sentry/node": "^7.85.0",
    "mixpanel": "^0.18.0",
    "amplitude-node": "^2.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^3.0.13",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/multer": "^1.4.11",
    "@types/sharp": "^0.32.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/ws": "^8.5.10",
    "@types/lodash": "^4.14.202",
    "@types/uuid": "^9.0.7",
    "@types/crypto-js": "^4.2.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/jest": "^29.5.8",
    "@types/supertest": "^2.0.16",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "nodemon": "^3.0.2",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "rimraf": "^5.0.5",
    "copyfiles": "^2.4.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  }
}

