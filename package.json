  "description": "Aideon Lite AI - Firebase Edition: The world's first hybrid autonomous AI system",
  "main": "functions/lib/index.js",
  "scripts": {
    "dev": "./deploy.sh emulator",
    "build": "./deploy.sh build",
    "deploy": "./deploy.sh deploy",
