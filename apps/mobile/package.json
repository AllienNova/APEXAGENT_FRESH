{
  "name": "aideon-lite-mobile",
  "version": "2.0.0",
  "description": "Aideon AI Lite - Complete Mobile Application with Superior Features",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:android:bundle": "cd android && ./gradlew bundleRelease",
    "build:ios": "cd ios && xcodebuild -workspace AideonLiteMobile.xcworkspace -scheme AideonLiteMobile -configuration Release -destination generic/platform=iOS -archivePath AideonLiteMobile.xcarchive archive",
    "clean": "react-native clean-project-auto",
    "postinstall": "cd ios && pod install",
    "dev": "react-native start --reset-cache",
    "android:dev": "react-native run-android --variant=debug",
    "ios:dev": "react-native run-ios --configuration Debug",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e:android": "detox test --configuration android.emu.debug",
    "e2e:ios": "detox test --configuration ios.sim.debug"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-native-community/netinfo": "^11.2.1",
    "@react-native-picker/picker": "^2.6.1",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/drawer": "^6.6.6",
    "@reduxjs/toolkit": "^2.0.1",
    "react": "18.2.0",
    "react-native": "0.73.2",
    "react-native-animatable": "^1.4.0",
    "react-native-biometrics": "^3.0.1",
    "react-native-chart-kit": "^6.12.0",
    "react-native-contacts": "^7.0.8",
    "react-native-device-info": "^10.12.0",
    "react-native-document-picker": "^9.1.1",
    "react-native-fast-image": "^8.6.3",
    "react-native-file-access": "^3.0.4",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-image-picker": "^7.1.0",
    "react-native-keychain": "^8.2.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-modal": "^13.0.1",
    "react-native-orientation-locker": "^1.7.0",
    "react-native-permissions": "^4.1.5",
    "react-native-push-notification": "^8.1.1",
    "react-native-reanimated": "^3.6.2",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "^3.29.0",
    "react-native-splash-screen": "^3.3.0",
    "react-native-svg": "^14.1.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-voice": "^3.2.4",
    "react-native-webview": "^13.6.4",
    "react-redux": "^9.1.0",
    "redux-persist": "^6.0.0",
    "react-native-camera": "^4.2.1",
    "react-native-audio-recorder-player": "^3.6.6",
    "react-native-share": "^10.0.2",
    "react-native-calendar-picker": "^7.1.4",
    "react-native-progress": "^5.0.1",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-super-grid": "^4.9.7",
    "react-native-tab-view": "^3.5.2",
    "react-native-toast-message": "^2.2.0",
    "react-native-uuid": "^2.0.1",
    "react-native-video": "^5.2.1",
    "react-native-zip-archive": "^6.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.8",
    "@babel/runtime": "^7.23.8",
    "@react-native/eslint-config": "^0.73.2",
    "@react-native/metro-config": "^0.73.3",
    "@tsconfig/react-native": "^3.0.2",
    "@types/react": "^18.2.48",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^18.0.7",
    "babel-jest": "^29.7.0",
    "detox": "^20.13.5",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "0.77.0",
    "prettier": "^3.2.4",
    "react-test-renderer": "18.2.0",
    "typescript": "5.3.3",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=8"
  },
  "keywords": [
    "react-native",
    "ai",
    "artificial-intelligence",
    "mobile",
    "aideon",
    "chat",
    "assistant",
    "hybrid",
    "enterprise",
    "multi-agent",
    "llm",
    "automation"
  ],
  "author": "Manus AI <manus@alliennova.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AllienNova/APEXAGENT_FRESH.git"
  },
  "bugs": {
    "url": "https://github.com/AllienNova/APEXAGENT_FRESH/issues"
  },
  "homepage": "https://github.com/AllienNova/APEXAGENT_FRESH#readme",
  "react-native": {
    "android": {
      "sourceDir": "android",
      "appName": "AideonLiteMobile"
    },
    "ios": {
      "project": "ios/AideonLiteMobile.xcodeproj"
    }
  },
  "detox": {
    "test-runner": "jest",
    "runner-config": "e2e/config.json",
    "configurations": {
      "android.emu.debug": {
        "type": "android.emulator",
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug",
        "device": {
          "avdName": "Pixel_3a_API_30_x86"
        }
      },
      "ios.sim.debug": {
        "type": "ios.simulator",
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/AideonLiteMobile.app",
        "build": "xcodebuild -workspace ios/AideonLiteMobile.xcworkspace -scheme AideonLiteMobile -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build",
        "device": {
          "type": "iPhone 14"
        }
      }
    }
  }
}

